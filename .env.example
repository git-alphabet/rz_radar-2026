# .env.example — 复制为 .env 并填写真实值
# .env 已在 .gitignore 中，不会提交到 git

# ── Docker Hub ────────────────────────────────────────────────
DOCKER_HUB_USER=alphabet2006

# 镜像名（不含用户名前缀）
IMAGE_NAME=rz-radar-2026

# 镜像标签 — Build & Push 任务会自动用时间戳（如 20250313-1430）覆盖
# 手动固定版本时取消注释
# IMAGE_TAG=20250313-1430

# ── 串口 ──────────────────────────────────────────────────────
# 实际串口路径，如 /dev/ttyUSB0 / /dev/ttyACM0
SERIAL_PORT=/dev/ttyUSB0

# ── 构建代理（宿主机代理端口，默认 7897）────────────────────
# Docker build 时会通过 host.docker.internal:HOST_PROXY_PORT 访问代理
# HOST_PROXY_PORT=7897

# ── X11 显示（通常不用改）────────────────────────────────────
# DISPLAY=:0
